.container { padding: var(--spacing-sm); }
.tabs { display: flex; margin-bottom: var(--spacing-md); }
.tab { flex: 1; text-align: center; padding: var(--spacing-sm); font-size: 28rpx; color: var(--text-secondary); border-bottom: 4rpx solid transparent; }
.tab.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: bold; }

/* Streaming */
.stream-container { min-height: 300rpx; padding: 20rpx 0; }
.stream-text { font-size: 28rpx; color: var(--text-primary); line-height: 1.8; white-space: pre-wrap; }
.cursor { color: var(--primary); font-weight: bold; }
.cursor.blink { animation: blink 0.8s infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
.stream-loading { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.stream-hint { font-size: 26rpx; color: var(--text-hint); margin-top: 20rpx; }
.dot-pulse {
  width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--primary);
  animation: pulse-dot 0.8s ease-in-out infinite;
}
@keyframes pulse-dot { 0%, 100% { transform: scale(1); opacity: 0.4; } 50% { transform: scale(1.8); opacity: 1; } }

/* Results */
.content { min-height: 400rpx; }
.fade-in { animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.advice-card { display: flex; align-items: flex-start; background: var(--bg-card); border-radius: var(--radius-md); padding: 20rpx; margin-bottom: 12rpx; border-left: 6rpx solid var(--primary); }
.advice-num { width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center; background: var(--primary); color: var(--text-white); border-radius: 50%; font-size: 24rpx; flex-shrink: 0; margin-right: var(--spacing-sm); }
.advice-text { font-size: 28rpx; color: var(--text-primary); line-height: 1.6; flex: 1; }
.eval-card { background: var(--bg-card); border-radius: var(--radius-md); padding: 20rpx; margin-bottom: var(--spacing-sm); }
.eval-label { font-size: 24rpx; color: var(--text-hint); margin-bottom: var(--spacing-xs); display: block; }
.eval-text { font-size: 28rpx; color: var(--text-primary); line-height: 1.6; }
.section-label { font-size: 26rpx; color: var(--text-hint); margin-bottom: 12rpx; display: block; }

/* Empty */
.empty-state { display: flex; justify-content: center; align-items: center; min-height: 300rpx; }
.empty-text { font-size: 28rpx; color: var(--text-hint); }

/* Footer */
.footer-info { display: flex; justify-content: space-between; align-items: center; margin-top: var(--spacing-md); padding: var(--spacing-sm) 0; }
.gen-time { font-size: 24rpx; color: var(--text-disabled); }
.refresh-btn { font-size: 24rpx; }
