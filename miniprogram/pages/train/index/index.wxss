.category-section { padding: var(--spacing-md); }
.category-card { display: flex; align-items: center; padding: var(--spacing-lg); margin-bottom: var(--spacing-sm); }
.category-icon { font-size: 48rpx; margin-right: var(--spacing-md); }
.category-info { flex: 1; display: flex; flex-direction: column; }
.arrow { color: var(--text-hint); font-size: 32rpx; }

.plan-card { display: flex; margin-bottom: var(--spacing-sm); padding: 0; overflow: hidden; }
.plan-cover { width: 160rpx; height: 120rpx; border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
.plan-meta { flex: 1; padding: var(--spacing-md); display: flex; flex-direction: column; justify-content: center; }
.create-entry { text-align: center; }
.difficulty-badge { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: var(--radius-xl); }
.difficulty-badge.d1 { background: rgba(34,197,94,0.1); color: var(--diff-beginner); }
.difficulty-badge.d2 { background: rgba(245,158,11,0.1); color: var(--diff-intermediate); }
.difficulty-badge.d3 { background: rgba(255,107,74,0.1); color: var(--accent); }
.create-entry { text-align: center; }
.create-btn { background: var(--gradient-primary); color: var(--text-white); border-radius: var(--radius-xl); font-size: 30rpx; padding: 24rpx 0; width: 80%; }
.history-btn { background: var(--bg-card); color: var(--primary); border-radius: var(--radius-xl); font-size: 28rpx; padding: 20rpx 0; width: 80%; border: 2rpx solid var(--primary); }
.today-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  margin: var(--spacing-md);
  background: linear-gradient(135deg, rgba(26,86,219,0.06), rgba(26,86,219,0.02));
  border-left: 6rpx solid var(--primary);
}
.today-left { display: flex; flex-direction: column; }
.today-label { font-size: 20rpx; color: var(--primary); font-weight: bold; text-transform: uppercase; }
.today-name { font-size: 34rpx; font-weight: bold; color: var(--text-primary); margin: 4rpx 0; }
