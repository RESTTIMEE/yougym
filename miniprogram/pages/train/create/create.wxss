.container { padding: var(--spacing-sm); padding-bottom: 120rpx; }

.section { background: var(--bg-card); border-radius: var(--radius-md); padding: var(--spacing-md); margin-bottom: var(--spacing-sm); }
.section-title { font-size: 32rpx; font-weight: bold; color: var(--text-primary); display: block; margin-bottom: var(--spacing-sm); }

.form-group { margin-bottom: 16rpx; }
.form-label { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 8rpx; display: block; }
.form-input { background: var(--bg-input); border-radius: var(--radius-sm); padding: 16rpx; font-size: 28rpx; border: 1rpx solid var(--border); }
.form-input:focus { border-color: var(--primary); }
.form-textarea { background: var(--bg-input); border-radius: var(--radius-sm); padding: 16rpx; font-size: 28rpx; border: 1rpx solid var(--border); width: 100%; min-height: 100rpx; box-sizing: border-box; }
.form-row { display: flex; gap: 16rpx; }
.flex-1 { flex: 1; }
.picker-value { background: var(--bg-input); border-radius: var(--radius-sm); padding: 16rpx; font-size: 28rpx; color: var(--text-primary); border: 1rpx solid var(--border); }
.slider-row { display: flex; align-items: center; }
.slider-row slider { flex: 1; }
.slider-tag { width: 60rpx; text-align: center; font-size: 26rpx; color: var(--primary); font-weight: bold; }

/* 训练日编辑器 */
.day-editor { background: var(--bg-card); border-radius: var(--radius-md); margin-bottom: var(--spacing-sm); overflow: hidden; border: 1rpx solid var(--border); }
.day-editor.expanded { border-color: var(--primary); }
.day-editor-header { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 20rpx; }
.deh-left { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.deh-input-wrap { flex: 1; }
.day-color-dot { width: 10rpx; height: 48rpx; border-radius: 5rpx; flex-shrink: 0; }
.day-name-input { font-size: 28rpx; font-weight: bold; border-bottom: 2rpx solid var(--primary); padding: 4rpx 0; }
.deh-actions { display: flex; align-items: center; gap: 12rpx; }
.action-icon.del { color: var(--accent); font-size: 22rpx; padding: 4rpx 8rpx; }
.day-arrow { font-size: 24rpx; color: var(--text-hint); transition: transform 0.2s; }
.day-arrow.open { transform: rotate(180deg); }

.day-editor-body { border-top: 1rpx solid var(--border); padding: 16rpx 20rpx; }
.exercise-editor { background: var(--bg-input); border-radius: var(--radius-sm); padding: 12rpx; margin-bottom: 8rpx; }
.ex-editor-header { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.ex-remove { color: var(--danger); font-size: 24rpx; padding: 4rpx 8rpx; }
.ex-name-input { width: 100%; height: 64rpx; background: var(--bg-card); border-radius: 8rpx; padding: 0 12rpx; font-size: 28rpx; margin-bottom: 8rpx; box-sizing: border-box; }
.ex-nums { display: flex; gap: 8rpx; }
.ex-num-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.num-input-sm { width: 100%; height: 56rpx; text-align: center; background: var(--bg-card); border-radius: 8rpx; font-size: 26rpx; box-sizing: border-box; }
.add-ex-btn { width: 100%; height: 72rpx; background: transparent; border: 2rpx dashed var(--border); border-radius: 12rpx; color: var(--text-secondary); font-size: 26rpx; display: flex; align-items: center; justify-content: center; }

.submit-btn {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--gradient-primary); color: var(--text-white);
  border-radius: 0; padding: 28rpx; font-size: 32rpx; font-weight: bold;
}
.submit-btn[disabled] { opacity: 0.6; }
