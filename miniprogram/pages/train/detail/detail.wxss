.plan-header { padding: 0; overflow: hidden; }
.cover-wrap { position: relative; width: 100%; height: 360rpx; }
.plan-cover { width: 100%; height: 100%; }
.cover-gradient { position: absolute; bottom: 0; left: 0; right: 0; height: 50%; background: linear-gradient(to top, rgba(0,0,0,0.5), transparent); }
.cover-tag { position: absolute; top: var(--spacing-md); right: var(--spacing-md); background: rgba(0,0,0,0.5); color: #fff; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: var(--radius-xl); }

.day-card { padding: 0; overflow: hidden; margin-bottom: var(--spacing-sm); }
.day-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--spacing-md);
}
.day-header-left { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.day-color-line { width: 8rpx; height: 56rpx; border-radius: 4rpx; flex-shrink: 0; }
.day-arrow { font-size: 24rpx; color: var(--text-hint); transition: transform 0.2s; }
.day-arrow.open { transform: rotate(180deg); }

.day-body { border-top: 1rpx solid var(--border); padding: var(--spacing-sm) 0; }
.exercise-row {
  display: flex; align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
}
.exercise-row:active { background: rgba(0,0,0,0.04); }
.ex-thumb { width: 80rpx; height: 56rpx; border-radius: 8rpx; margin-right: var(--spacing-sm); flex-shrink: 0; }
.ex-info { flex: 1; display: flex; flex-direction: column; }

.bottom-btn { padding: var(--spacing-md) var(--spacing-lg) calc(var(--spacing-md) + env(safe-area-inset-bottom)); display: flex; justify-content: center; }
.btn-pill {
  width: 520rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--gradient-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(26,86,219,0.3);
}
