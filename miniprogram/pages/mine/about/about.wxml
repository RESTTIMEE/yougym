<view class="page-container">
  <view class="about-header">
    <image class="app-icon" src="/assets/logo.png" mode="aspectFit" />
    <text class="app-name">优健 YouGym</text>
    <text class="app-version">v{{version}}</text>
  </view>

  <view class="about-desc card">
    <text>{{description}}</text>
  </view>

  <view class="about-section card">
    <text class="section-title">技术栈</text>
    <view class="tech-list">
      <text class="tech-item">前端：微信小程序 + TypeScript</text>
      <text class="tech-item">后端：NestJS + Prisma</text>
      <text class="tech-item">数据：MySQL + Redis</text>
      <text class="tech-item">AI：大语言模型驱动</text>
    </view>
  </view>

  <view class="about-section card">
    <text class="section-title">联系我们</text>
    <text class="contact-text">{{contactEmail}}</text>
  </view>

  <view class="copyright">
    <text>Copyright &copy; 2026 YouGym</text>
  </view>
</view>
