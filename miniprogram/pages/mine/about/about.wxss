.page-container {
  padding: 24rpx;
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.app-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #E8EDF5;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-top: 16rpx;
}

.app-version {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

.about-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.about-section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.tech-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tech-item {
  font-size: 26rpx;
  color: #555;
}

.contact-text {
  font-size: 26rpx;
  color: #1A56DB;
}

.copyright {
  margin-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  color: #AAA;
}
