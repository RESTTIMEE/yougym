.page-container {
  padding: 24rpx;
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.app-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #E8EDF5;
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 16rpx;
}

.app-version {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.about-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.about-section {
  margin-top: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.tech-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tech-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.contact-text {
  font-size: 26rpx;
  color: var(--primary);
}

.copyright {
  margin-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-disabled);
}
