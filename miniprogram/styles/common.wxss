/* 优健 公共样式 */

/* 卡片 */
.card { background: var(--bg-card); border-radius: var(--radius-md); padding: var(--spacing-md); margin: var(--spacing-sm) var(--spacing-md); box-shadow: var(--shadow-card); }

/* Flex 布局 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

/* 文字 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-white { color: var(--text-white); }
.text-center { text-align: center; }
.text-bold { font-weight: bold; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }

/* 间距 */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

/* 按钮 */
.btn-primary { background: var(--primary); color: var(--text-white); border-radius: var(--radius-md); padding: var(--spacing-sm) var(--spacing-lg); text-align: center; font-weight: bold; }
.btn-primary:active { opacity: 0.8; transform: scale(0.98); }
.btn-accent { background: var(--accent); color: var(--text-white); border-radius: var(--radius-md); padding: var(--spacing-sm) var(--spacing-lg); text-align: center; font-weight: bold; }
.btn-accent:active { opacity: 0.8; transform: scale(0.98); }

/* 标签 */
.badge { display: inline-block; padding: 4rpx 12rpx; border-radius: var(--radius-sm); font-size: 22rpx; }
.badge-primary { background: rgba(26,86,219,0.1); color: var(--primary); }
.badge-accent { background: var(--accent-light); color: var(--accent); }
.badge-success { background: var(--success-light); color: var(--success); }
.badge-warning { background: var(--warning-light); color: var(--warning); }

/* 分割线 */
.divider { height: 1rpx; background: var(--border); margin: var(--spacing-sm) 0; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: var(--spacing-xl) 0; color: var(--text-hint); }

/* 交互 */
.scale-active { transition: transform 0.15s ease, opacity 0.15s ease; }
.scale-active:active { transform: scale(0.96); opacity: 0.85; }

/* 入场动画 */
.fade-in { animation: fadeIn var(--transition-slow) ease both; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }

/* 骨架屏 */
.skeleton { background: linear-gradient(90deg, #E8EAED 25%, #F0F1F3 50%, #E8EAED 75%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; border-radius: var(--radius-sm); }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
.skeleton-text { height: 28rpx; margin-bottom: 12rpx; }
.skeleton-title { height: 36rpx; width: 60%; margin-bottom: 16rpx; }
.skeleton-card { height: 160rpx; border-radius: var(--radius-md); }
.skeleton-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }

/* 输入框错误状态 */
.input-error { border-color: var(--danger) !important; animation: shake 0.4s ease; }
@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-8rpx); } 75% { transform: translateX(8rpx); } }
.error-text { color: var(--danger); font-size: 22rpx; margin-top: 4rpx; }

/* 输入框聚焦 */
.input-focus { border-color: var(--primary); box-shadow: 0 0 0 4rpx rgba(26,86,219,0.12); }

/* 按钮脉冲动效 */
.btn-pulse {
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(26, 86, 219, 0.4); }
  50% { box-shadow: 0 0 0 12rpx rgba(26, 86, 219, 0); }
}

/* 胶囊标签 */
.pill { display: inline-flex; align-items: center; padding: 6rpx 20rpx; border-radius: var(--radius-xl); font-size: 24rpx; }
.pill-active { background: var(--primary); color: var(--text-white); }
.pill-default { background: var(--bg-input); color: var(--text-secondary); }

/* 隐私协议 */
.privacy-agree {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-wrap: wrap;
}
.privacy-agree checkbox {
  transform: scale(0.7);
  margin-right: 8rpx;
}
.privacy-agree .link {
  color: var(--primary);
}
