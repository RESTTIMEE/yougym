.chart-wrapper { margin-bottom: var(--spacing-md); }
.chart-title { font-size: 28rpx; font-weight: bold; color: var(--text-primary); display: block; margin-bottom: var(--spacing-xs); padding-left: var(--spacing-xs); }
.chart-container { width: 100%; height: 360rpx; background: var(--bg-card); border-radius: var(--radius-md); overflow: hidden; }
.chart-placeholder { display: flex; align-items: center; justify-content: center; height: 360rpx; }
