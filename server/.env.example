# 微信小程序配置
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret

# 数据库 MySQL 9.7
# 可追加连接池参数: ?connection_limit=10&pool_timeout=30&socket_timeout=60
DATABASE_URL=mysql://root:password@localhost:3306/yougym?charset=utf8mb4

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (用于访问令牌签名)
JWT_SECRET=your_jwt_secret_key
# JWT 刷新令牌密钥 (用于 refresh_token 签名，建议与 JWT_SECRET 不同)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=7d

# AI服务 (DeepSeek / 通义千问)
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.deepseek.com/v1

# 对象存储 (阿里云OSS)
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_oss_key
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET=yougym

# 跨域配置 (多个域名用逗号分隔，留空则允许所有来源)
ALLOWED_ORIGINS=

# 服务端口
PORT=3000
